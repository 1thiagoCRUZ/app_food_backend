# =============================================================
# App Food Backend — Variáveis de Ambiente (EXEMPLO)
# Copie este arquivo para ".env" e preencha com seus dados reais.
# Este arquivo (.env.example) é seguro para ser versionado no git.
# =============================================================

# -------------------- Servidor --------------------
PORT=3000
NODE_ENV=development

# -------------------- Banco de Dados (PostgreSQL) --------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=food_db

# -------------------- Mercado Pago --------------------
# Obtenha em: https://www.mercadopago.com.br/developers/pt/reference
MERCADOPAGO_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# -------------------- Google Maps --------------------
# Ative as APIs: Geocoding API e Routes API em: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
JWT_SECRET=
JWT_EXPIRATION=
PORT=
NODE_ENV=
AWS_REGION=
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=